<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ page import="java.sql.*" %>
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Kết quả tuyển sinh</title>
    <style>
        .container { width: 500px; margin: 0 auto; border: 1px dashed #000; padding: 20px; }
        h2 { text-align: center; background-color: #d69ada; padding: 10px; margin-top: 0; }
        table { width: 100%; border-collapse: collapse; margin-top: 15px; }
        td { padding: 8px 10px; font-size: 16px; }
        .label { font-weight: bold; width: 45%; }
    </style>
</head>
<body>
    <div class="container">
        <h2>KẾT QUẢ TUYỂN SINH</h2>
        <%
            request.setCharacterEncoding("UTF-8");
            String sbd = request.getParameter("sbd");
            String hoten = request.getParameter("hoten");

            if (sbd != null && hoten != null && !sbd.trim().isEmpty() && !hoten.trim().isEmpty()) {
                Connection conn = null;
                PreparedStatement pstmt = null;
                ResultSet rs = null;
                try {
                    Class.forName("com.mysql.jdbc.Driver");
                    conn = DriverManager.getConnection("jdbc:mysql://localhost:3306/qlsv?useUnicode=true&characterEncoding=UTF-8", "root", "");
                    
                    String sql = "SELECT t.*, n.Tennganh FROM thisinh t JOIN nganh n ON t.Manganh = n.Manganh WHERE t.SoBD = ? AND t.Hoten = ?";
                    pstmt = conn.prepareStatement(sql);
                    pstmt.setString(1, sbd.trim());
                    pstmt.setString(2, hoten.trim());
                    rs = pstmt.executeQuery();

                    if (rs.next()) {
                        String gioiTinh = rs.getString("Gioitinh");
                        String ngaySinh = rs.getString("Ngaysinh");
                        String noiSinh = rs.getString("Noisinh");
                        String tenNganh = rs.getString("Tennganh");
                        int monCB = rs.getInt("MonCB");
                        int monCS = rs.getInt("MonCS");
                        int ngoaiNgu = rs.getInt("Ngoaingu");
                        
                        String ketQua = "Không trúng tuyển";
                        if (monCB >= 5 && monCS >= 5 && ngoaiNgu >= 50) {
                            ketQua = "Trúng tuyển";
                        }
        %>
        <table>
            <tr><td class="label">Số báo danh:</td><td><%= sbd %></td></tr>
            <tr><td class="label">Họ và tên thí sinh:</td><td><%= hoten %></td></tr>
            <tr><td class="label">Giới tính:</td><td><%= gioiTinh %></td></tr>
            <tr><td class="label">Ngày sinh:</td><td><%= ngaySinh %></td></tr>
            <tr><td class="label">Nơi sinh:</td><td><%= noiSinh %></td></tr>
            <tr><td class="label">Ngành thi tuyển:</td><td><b><%= tenNganh %></b></td></tr>
            <tr><td class="label">Môn cơ bản:</td><td><%= monCB %></td></tr>
            <tr><td class="label">Môn cơ sở:</td><td><%= monCS %></td></tr>
            <tr><td class="label">Ngoại ngữ:</td><td><%= ngoaiNgu %></td></tr>
            <tr><td class="label">Kết quả:</td><td><b><%= ketQua %></b></td></tr>
        </table>
        <%
                    } else {
                        out.println("<p style='text-align:center;'>Không tìm thấy thông tin thí sinh hợp lệ.</p>");
                    }
                } catch (Exception e) {
                    out.println("<p style='text-align:center;'>Lỗi kết nối cơ sở dữ liệu: " + e.getMessage() + "</p>");
                } finally {
                    if (rs != null) try { rs.close(); } catch(SQLException e) {}
                    if (pstmt != null) try { pstmt.close(); } catch(SQLException e) {}
                    if (conn != null) try { conn.close(); } catch(SQLException e) {}
                }
            } else {
                out.println("<p style='text-align:center;'>Dữ liệu không hợp lệ. Vui lòng quay lại và nhập đầy đủ thông tin.</p>");
            }
        %>
    </div>
</body>
</html>
            
